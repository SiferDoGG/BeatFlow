{
    "manifest_version": 3,
    "name": "Music Controller",
    "version": "1.0",
    "permissions": [
        "tabs",
        "scripting"
    ],
    "host_permissions": [
        "https://music.yandex.ru/*",
        "http://127.0.0.1:8000/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "https://music.yandex.ru/*"
            ],
            "js": [
                "content.js"
            ]
        }
    ]
}