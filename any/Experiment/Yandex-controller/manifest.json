{
    "manifest_version": 3,
    "name": "Music Controller",
    "version": "1.0",
    "permissions": [
        "tabs"
    ],
    "host_permissions": [
        "https://music.yandex.ru/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "https://music.yandex.ru/*"
            ],
            "js": [
                "content.js"
            ]
        }
    ],
    "action": {
        "default_popup": "popup.html"
    }
}