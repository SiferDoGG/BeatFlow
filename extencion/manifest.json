{
    "manifest_version": 3,
    "name": "Music Controller",
    "version": "2.0",
    "permissions": [
        "tabs"
    ],
    "host_permissions": [
        "https://music.yandex.ru/*",
        "https://open.spotify.com/*",
        "http://127.0.0.1:8000/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_popup": "popup.html"
    },
    "content_scripts": [
        {
            "matches": [
                "https://music.yandex.ru/*"
            ],
            "js": [
                "content/yandex.js"
            ]
        },
        {
            "matches": [
                "https://open.spotify.com/*"
            ],
            "js": [
                "content/spotify.js"
            ]
        }
    ]
}